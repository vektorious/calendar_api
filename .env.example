# Copy this to .env and fill in real values. .env is gitignored — never commit real secrets.

# Comma-separated API keys, one per consumer (e.g. Terminus, your laptop).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=changeme-generate-a-real-key,changeme-second-key-for-terminus

# Only needed if you're using the caldav source type against Nextcloud
NEXTCLOUD_APP_PASSWORD=
